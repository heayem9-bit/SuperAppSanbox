{
  "expo": {
    "name": "SuperAppSanbox",
    "slug": "SuperAppSanbox",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logos/app-logo.png",
    "scheme": "superappsanbox",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/logos/app-logo.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.SuperAppSanbox"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}